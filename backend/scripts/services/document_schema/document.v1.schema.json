{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://retainpdf.local/schemas/document.v1.schema.json",
  "title": "normalized_document_v1",
  "type": "object",
  "required": [
    "schema",
    "schema_version",
    "document_id",
    "source",
    "page_count",
    "pages",
    "derived",
    "markers"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "normalized_document_v1"
    },
    "schema_version": {
      "enum": ["1.1"]
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "doc_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object"
    },
    "page_count": {
      "type": "integer",
      "minimum": 0
    },
    "pages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/page"
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/asset"
      }
    },
    "derived": {
      "type": "object"
    },
    "markers": {
      "type": "object",
      "properties": {
        "reference_start": {
          "$ref": "#/$defs/reference_start"
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "bbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number"
      }
    },
    "derived": {
      "type": "object",
      "required": [
        "role",
        "by",
        "confidence"
      ],
      "additionalProperties": true,
      "properties": {
        "role": {
          "type": "string"
        },
        "by": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "continuation_hint": {
      "type": "object",
      "required": [
        "source",
        "group_id",
        "role",
        "scope",
        "reading_order",
        "confidence"
      ],
      "additionalProperties": true,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["", "provider"]
        },
        "group_id": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["", "single", "head", "middle", "tail"]
        },
        "scope": {
          "type": "string",
          "enum": ["", "intra_page", "cross_page"]
        },
        "reading_order": {
          "type": "integer",
          "minimum": -1
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "segment": {
      "type": "object",
      "required": [
        "type",
        "raw_type",
        "text",
        "bbox"
      ],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "text",
            "formula"
          ]
        },
        "raw_type": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        },
        "score": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "line": {
      "type": "object",
      "required": [
        "bbox",
        "spans"
      ],
      "additionalProperties": true,
      "properties": {
        "bbox": {
          "$ref": "#/$defs/bbox"
        },
        "spans": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/segment"
          }
        }
      }
    },
    "geometry": {
      "type": "object",
      "required": [
        "bbox"
      ],
      "additionalProperties": true,
      "properties": {
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "content": {
      "type": "object",
      "required": [
        "kind"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "text",
            "image",
            "table",
            "formula",
            "code",
            "unknown"
          ]
        },
        "text": {
          "type": "string"
        },
        "asset_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "translate",
        "translate_reason"
      ],
      "additionalProperties": true,
      "properties": {
        "translate": {
          "type": "boolean"
        },
        "translate_reason": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "provider",
        "raw_label",
        "raw_sub_type",
        "raw_bbox",
        "raw_path"
      ],
      "additionalProperties": true,
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "raw_label": {
          "type": "string"
        },
        "raw_sub_type": {
          "type": "string"
        },
        "raw_bbox": {
          "$ref": "#/$defs/bbox"
        },
        "raw_path": {
          "type": "string"
        }
      }
    },
    "asset": {
      "type": "object",
      "required": [
        "kind",
        "uri",
        "source"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string"
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string"
        }
      }
    },
    "block": {
      "type": "object",
      "required": [
        "block_id",
        "page_index",
        "order",
        "geometry",
        "content",
        "layout_role",
        "semantic_role",
        "structure_role",
        "policy",
        "provenance",
        "metadata",
        "source",
        "continuation_hint"
      ],
      "additionalProperties": true,
      "properties": {
        "block_id": {
          "type": "string",
          "minLength": 1
        },
        "page_index": {
          "type": "integer",
          "minimum": 0
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "formula",
            "image",
            "table",
            "code",
            "unknown"
          ]
        },
        "sub_type": {
          "type": "string"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        },
        "text": {
          "type": "string"
        },
        "lines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/line"
          }
        },
        "segments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/segment"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "derived": {
          "$ref": "#/$defs/derived"
        },
        "continuation_hint": {
          "$ref": "#/$defs/continuation_hint"
        },
        "metadata": {
          "type": "object"
        },
        "source": {
          "type": "object",
          "required": [
            "provider"
          ],
          "additionalProperties": true,
          "properties": {
            "provider": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "reading_order": {
          "type": "integer",
          "minimum": 0
        },
        "geometry": {
          "$ref": "#/$defs/geometry"
        },
        "content": {
          "$ref": "#/$defs/content"
        },
        "layout_role": {
          "type": "string",
          "enum": [
            "title",
            "heading",
            "paragraph",
            "list_item",
            "caption",
            "header",
            "footer",
            "footnote",
            "page_number",
            "unknown"
          ]
        },
        "semantic_role": {
          "type": "string",
          "enum": [
            "body",
            "abstract",
            "reference",
            "metadata",
            "affiliation",
            "acknowledgement",
            "unknown"
          ]
        },
        "policy": {
          "$ref": "#/$defs/policy"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    },
    "page": {
      "type": "object",
      "required": [
        "page_index",
        "width",
        "height",
        "unit",
        "blocks"
      ],
      "additionalProperties": true,
      "properties": {
        "page_index": {
          "type": "integer",
          "minimum": 0
        },
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "const": "pt"
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/block"
          }
        }
      }
    },
    "reference_start": {
      "type": "object",
      "required": [
        "page_index",
        "block_id",
        "order"
      ],
      "additionalProperties": true,
      "properties": {
        "page_index": {
          "type": "integer",
          "minimum": 0
        },
        "block_id": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
